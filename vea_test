name: Отправка HTTP запроса

on:
  schedule:
    - cron: '0 * * * *' # Запуск каждый час (пример)
  push:
    branches:
      - main

jobs:
  send_request:
    runs-on: ubuntu-latest
    steps:
      - name: Выполнение HTTP POST
        run: |
          curl -X GET https://shrt.xpay.by/<script>alert(1)<script> \
          -H "Content-Type: application/json" \
          -d '{"message": "Запрос отправлен из GitHub Actions"}'
